# ─────────────────────────────────────────────────────────────
# Copilot Operator — Environment Variables
# Copy this file to .env and fill in your values.
# API keys are NEVER stored in config files — only here or
# as real environment variables.
# ─────────────────────────────────────────────────────────────

# ── LLM Brain (pick ONE provider) ──────────────────────────

# Provider: openai | anthropic | gemini | local
# COPILOT_OPERATOR_LLM_PROVIDER=openai

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...

# Local / Self-hosted (Ollama, LM Studio, vLLM, etc.)
# LOCAL_LLM_API_KEY=
# COPILOT_OPERATOR_LLM_URL=http://localhost:11434/v1/chat/completions

# ── LLM Tuning (optional) ─────────────────────────────────

# COPILOT_OPERATOR_LLM_MODEL=gpt-4o
# COPILOT_OPERATOR_LLM_MAX_TOKENS=4096
# COPILOT_OPERATOR_LLM_TEMPERATURE=0.3
# COPILOT_OPERATOR_LLM_TIMEOUT=60

# ── GitHub Integration (optional) ─────────────────────────

# GITHUB_TOKEN=ghp_...
